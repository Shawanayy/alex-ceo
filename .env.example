# Copy this file to .env and fill in real values. Never commit or share .env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal Telegram numeric user ID (Alex only responds to this ID).
# Get it by messaging @userinfobot on Telegram.
OWNER_TELEGRAM_USER_ID=

# Supabase project (shawanayy@gmail.com's Project)
SUPABASE_URL=https://ymfuulgwqyjpmtegcvrc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Claude API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the model Alex thinks with (defaults to claude-sonnet-5)
# Use claude-haiku-4-5-20251001 for lower cost.
ALEX_MODEL=claude-sonnet-5

# ── Google OAuth (Phase 2 - Calendar + Gmail, used by the Admin Agent) ──
# One OAuth client covers both Calendar and Gmail scopes. Enable both the
# Calendar API and the Gmail API on this same Google Cloud project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:53682/oauth2callback
# Run `node src/google/googleAuth.js` once to generate this — see console output.
GOOGLE_REFRESH_TOKEN=

# ── n8n (LifeOS capture workflow) ──
# Webhook URL for the n8n "lifeos-capture" workflow (from the Webhook node's
# Production URL, not the workflow editor link). Alex POSTs { text, source } here.
N8N_WEBHOOK_URL=

# ── Default Supabase user (Shane's row in public.users) ──
# Used by the Learning & Career Agent (and any future agent) to scope
# user_id-owned tables like classes, assignments, study_sessions, flashcards.
DEFAULT_USER_ID=

# ── Alex-through-Claude, local (MCP bridge, src/mcpServer.js) ──
# No new env vars required — it reuses ANTHROPIC_API_KEY, SUPABASE_*, and
# DEFAULT_USER_ID above. Run `npm run mcp` to start it, or point a Claude app's
# MCP config at "node src/mcpServer.js" (see the comment at the top of that file).
# Only works with classic Claude Desktop — Cowork can't reach a local stdio process.

# ── Alex-through-Claude, remote (MCP bridge for Cowork, src/remoteMcpServer.js) ──
# A publicly hosted HTTP version of the bridge above, meant to be deployed (e.g. to
# Render — see render.yaml) and registered as a custom connector in Cowork.
# ALEX_REMOTE_MCP_TOKEN is a shared secret you invent — every request to the deployed
# server must send it as `Authorization: Bearer <token>`, or Alex refuses to respond.
# Generate one yourself with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Set this in Render's dashboard (not here) — never commit the real value.
ALEX_REMOTE_MCP_TOKEN=
